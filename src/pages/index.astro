---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');

// Optionally filter out projects that aren't public if this is a public build
const isInternalDev = import.meta.env.DEV || import.meta.env.PUBLIC_INTERNAL_BUILD === 'true';
const visibleProjects = isInternalDev ? projects : projects.filter(p => p.data.public_visibility);
---

<Layout title="Professional Engineering Portfolio">
	<section class="py-12 md:py-20 max-w-2xl">
		<h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-slate-900 mb-6">
			Building robust systems<br/>
            <span class="text-emerald-600">for complex problems.</span>
		</h1>
		<p class="text-xl text-slate-600 leading-relaxed mb-10">
			A curated collection of web applications, technical write-ups, and developer notes capturing my professional journey.
		</p>
	</section>

	<section>
		<h2 class="text-2xl font-bold text-slate-900 mb-8 border-b border-slate-200 pb-4">Featured Projects</h2>
		<div class="grid gap-8 sm:grid-cols-2">
			{visibleProjects.map((project: any) => (
				<a href={`${import.meta.env.BASE_URL}projects/${project.id}/`} class="group relative block bg-white rounded-2xl p-6 shadow-sm ring-1 ring-slate-200 hover:shadow-md hover:ring-emerald-200 transition-all duration-300">
					<div class="flex justify-between items-start mb-4">
						<span class={`px-2.5 py-0.5 rounded-full text-xs font-medium ${project.data.status === 'Live' ? 'bg-emerald-100 text-emerald-800' : 'bg-slate-100 text-slate-600'}`}>
							{project.data.status}
						</span>
					</div>
					<h3 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-emerald-600 transition-colors">
						{project.data.title}
					</h3>
					<p class="text-sm text-slate-600 mb-6 line-clamp-2">
						{project.data.summary}
					</p>
                    <div class="flex flex-wrap gap-2 mt-auto">
                        {project.data.tech_stack.slice(0, 3).map((tech: string) => (
                            <span class="text-xs font-medium text-slate-500 bg-slate-50 px-2 py-1 rounded-md border border-slate-100">{tech}</span>
                        ))}
                    </div>
				</a>
			))}
		</div>
	</section>
</Layout>
