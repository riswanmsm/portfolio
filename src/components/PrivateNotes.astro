---
// PrivateNotes.astro
const isInternalDev = import.meta.env.DEV || import.meta.env.PUBLIC_INTERNAL_BUILD === 'true';
---

{isInternalDev ? (
  <div class="mt-12 p-6 bg-slate-900 border border-slate-700 rounded-lg shadow-inner">
    <div class="flex items-center gap-2 mb-4 text-emerald-400 font-semibold border-b border-slate-700 pb-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
      </svg>
      Internal Developer Notes
    </div>
    <div class="prose prose-invert prose-emerald max-w-none text-sm">
      <slot />
    </div>
  </div>
) : null}
