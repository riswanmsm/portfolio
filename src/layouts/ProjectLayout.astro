---
const { frontmatter } = Astro.props;

// Conditional rendering checks
const isInternalDev = import.meta.env.DEV || import.meta.env.PUBLIC_INTERNAL_BUILD === 'true';

// Determine if we should show this project
if (!frontmatter.public_visibility && !isInternalDev) {
  return new Response("Unauthorized", { status: 403 });
}
---

<article class="max-w-4xl mx-auto">
  <a href={import.meta.env.BASE_URL} class="inline-flex items-center gap-2 text-sm font-medium text-slate-500 hover:text-emerald-600 mb-8 transition-colors group not-prose">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
    </svg>
    Back to Projects
  </a>

  <header class="mb-16 not-prose">
    <div class="flex flex-wrap items-center gap-3 mb-6">
      <span class="px-3 py-1.5 rounded-full text-xs font-semibold bg-emerald-100 text-emerald-800 shadow-sm border border-emerald-200">
        {frontmatter.status}
      </span>
      {frontmatter.tags.map((tag: string) => (
          <span class="px-3 py-1.5 rounded-full text-xs font-medium bg-slate-100 text-slate-600 shadow-sm border border-slate-200">
            {tag}
          </span>
      ))}
    </div>
    <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-slate-900 mb-6 leading-tight">
      {frontmatter.title}
    </h1>
    <p class="text-xl md:text-2xl text-slate-600 mb-12 leading-relaxed max-w-3xl">
      {frontmatter.summary}
    </p>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6 p-6 md:p-8 bg-white rounded-2xl border border-slate-200 shadow-sm">
      <div class="flex flex-col gap-1.5">
        <div class="flex items-center gap-2 text-slate-500 font-medium text-sm mb-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          Role
        </div>
        <p class="text-slate-900 font-semibold">{frontmatter.role}</p>
      </div>
      <div class="flex flex-col gap-1.5">
        <div class="flex items-center gap-2 text-slate-500 font-medium text-sm mb-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          Timeline
        </div>
        <p class="text-slate-900 font-semibold">{frontmatter.dates}</p>
      </div>
      <div class="flex flex-col gap-1.5">
        <div class="flex items-center gap-2 text-slate-500 font-medium text-sm mb-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
          </svg>
          Stack
        </div>
        <div class="flex flex-wrap gap-1.5">
          {frontmatter.tech_stack.slice(0, 3).map((tech: string) => (
            <span class="text-sm font-medium text-slate-700 bg-slate-50 px-2 py-0.5 rounded border border-slate-200">{tech}</span>
          ))}
          {frontmatter.tech_stack.length > 3 && (
            <span class="text-sm font-medium text-slate-500 px-1 py-0.5" title={frontmatter.tech_stack.slice(3).join(', ')}>+{frontmatter.tech_stack.length - 3}</span>
          )}
        </div>
      </div>
      <div class="flex flex-col gap-1.5">
        <div class="flex items-center gap-2 text-slate-500 font-medium text-sm mb-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
          </svg>
          Links
        </div>
        <div class="flex flex-col gap-2">
          {frontmatter.links?.map((link: string) => (
              <a href={link} target="_blank" class="inline-flex items-center gap-1.5 text-emerald-600 hover:text-emerald-700 font-semibold transition-colors group">
                View Live
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
          ))}
          {(!frontmatter.links || frontmatter.links.length === 0) && (
            <span class="text-slate-400 italic text-sm">None available</span>
          )}
        </div>
      </div>
    </div>
  </header>
  
  <div class="prose prose-slate prose-lg max-w-none 
    prose-headings:font-bold prose-headings:tracking-tight prose-headings:text-slate-900
    prose-h2:text-3xl prose-h2:border-b prose-h2:border-slate-100 prose-h2:pb-4 prose-h2:mb-8 prose-h2:mt-16
    prose-h3:text-2xl prose-h3:mt-8
    prose-p:text-slate-600 prose-p:leading-relaxed
    prose-a:text-emerald-600 hover:prose-a:text-emerald-700 prose-a:font-medium prose-a:underline-offset-4
    prose-strong:text-slate-900 prose-strong:font-semibold
    prose-ul:text-slate-600 prose-li:marker:text-emerald-500
    prose-img:rounded-2xl prose-img:shadow-lg prose-img:border prose-img:border-slate-100
    prose-hr:border-slate-200 prose-hr:my-12">
    <slot />
  </div>
</article>
